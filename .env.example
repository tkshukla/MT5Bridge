# Copy to .env and fill in real values. Never commit the filled-in .env — it is
# git-ignored. In production, move it to /etc/mt5bridge/mt5bridge.env (see
# docs/UBUNTU_SETUP.md) instead of keeping it in the repo checkout.

APP_ENV=production
LOG_LEVEL=INFO

# --- Postgres -----------------------------------------------------------------
POSTGRES_DB=mt5bridge
POSTGRES_USER=mt5bridge
POSTGRES_PASSWORD=                      # openssl rand -hex 32
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Redis ----------------------------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                         # openssl rand -hex 32
REDIS_DB=0

# --- JWT --------------------------------------------------------------------
JWT_SECRET_KEY=                         # openssl rand -hex 32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# --- Order confirmation anti-replay -----------------------------------------
ORDER_TOKEN_TTL_SECONDS=60

# --- Kotak Neo (see README.md "Kotak Neo API disclaimer") --------------------
KOTAK_NEO_BASE_URL=https://gw-napi.kotaksecurities.com
KOTAK_NEO_WS_URL=wss://mlhsi.kotaksecurities.com/realtime
KOTAK_NEO_API_KEY=
KOTAK_NEO_API_SECRET=
KOTAK_NEO_CLIENT_ID=
KOTAK_NEO_MOBILE_NUMBER=
KOTAK_NEO_PASSWORD=
KOTAK_NEO_TOTP_SECRET=
KOTAK_NEO_POLL_INTERVAL_SECONDS=5.0

# Explicit, auditable kill-switch placeholder — see docs/SECURITY.md. Nothing in
# this codebase currently reads this flag to enable automated order placement.
AUTOMATED_TRADING_ENABLED=false

# --- Retention ------------------------------------------------------------------
TICK_RETENTION_DAYS=90

# --- Deployment ---------------------------------------------------------------
DOMAIN=                                 # e.g. mt5bridge.yourdomain.com — for Certbot
MT5_STATIC_IP=                          # Windows desktop's egress IP, for Nginx allowlist
BACKUP_REMOTE=                          # optional rsync target for off-box backups, e.g. user@host:/backups/mt5bridge

# --- Monitoring -----------------------------------------------------------------
GRAFANA_ADMIN_PASSWORD=                 # openssl rand -hex 16
