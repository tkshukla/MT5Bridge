[Unit]
Description=MT5Bridge tick/candle retention (drop old partitions, enforce TICK_RETENTION_DAYS)
After=mt5bridge.service
Requires=mt5bridge.service

[Service]
Type=oneshot
WorkingDirectory=/opt/mt5bridge
EnvironmentFile=/etc/mt5bridge/mt5bridge.env
ExecStart=/opt/mt5bridge/scripts/retention.sh
