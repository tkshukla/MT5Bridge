# Force LF regardless of the checking-out machine's git config — shell scripts in this
# repo run on Ubuntu and a CRLF shebang line ("#!/usr/bin/env bash\r") fails to exec.
*.sh text eol=lf
*.py text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.conf text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.sql text eol=lf
Dockerfile text eol=lf

# MQL5 files are edited/compiled on Windows in MetaEditor — leave line endings alone.
*.mq5 -text
*.mqh -text
